# Ports
SERVER_PORT=8000
CLIENT_PORT=8080

# Compose
COMPOSE_PROJECT_NAME=toolbox

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:8080

# Image tags
API_IMAGE=toolbox/api:local
CLIENT_IMAGE=toolbox/client:local

# Build args
PYTHON_VERSION=3.11
NODE_VERSION=20
# Private repository access (sg-spec)
# Generate a GitHub PAT with 'repo' scope: https://github.com/settings/tokens
# Required for full Smart Guitar integration; optional for core features
SG_SPEC_TOKEN=


# Production (for docker-compose.production.yml)
NGINX_PORT=80
NGINX_IMAGE=ghcr.io/yourorg/luthiers-toolbox-nginx:latest

# =============================================================================
# SUPABASE AUTHENTICATION (Phase 3 SaaS)
# =============================================================================
# Get these values from your Supabase project settings

# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (public, safe for client-side)
SUPABASE_ANON_KEY=eyJ...

# Supabase Service Role Key (SECRET - server-side only)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT Secret (from Supabase Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# Database URL (from Supabase Settings > Database > Connection string)
# Use transaction mode for serverless deployments
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# Auth mode: "supabase" for production, "header" for dev
AUTH_MODE=header

# Connection pooling (set to 1 if using Supabase connection pooler)
USE_PGBOUNCER=0
