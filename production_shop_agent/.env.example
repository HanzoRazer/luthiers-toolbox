# =============================================================================
# Site Generator API - Environment Configuration
# =============================================================================
# Copy this file to .env and update with your actual values
# Never commit .env to version control!

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------

# API key required for all protected endpoints
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SITE_GENERATOR_API_KEY=your-secure-api-key-here-change-this

# Claude API key for generating sites
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# -----------------------------------------------------------------------------
# Job Management
# -----------------------------------------------------------------------------

# Directory where generated sites are stored
SITE_JOBS_DIR=./site_jobs

# Maximum number of sites that can be generated simultaneously
MAX_CONCURRENT_JOBS=3

# How long to keep completed jobs before auto-deletion (in hours)
# Default: 48 hours (2 days)
JOB_RETENTION_HOURS=48

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true

# Maximum number of generation requests per hour per API key
RATE_LIMIT_PER_HOUR=10

# -----------------------------------------------------------------------------
# Webhooks (Optional)
# -----------------------------------------------------------------------------

# Enable webhook notifications when jobs complete
WEBHOOK_ENABLED=false

# Secret key for signing webhook payloads (HMAC SHA-256)
# Recommended: generate with python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=your-webhook-secret-here

# -----------------------------------------------------------------------------
# File Limits
# -----------------------------------------------------------------------------

# Maximum size of site specification JSON in KB
MAX_SPEC_SIZE_KB=100

# -----------------------------------------------------------------------------
# CORS (Optional - configure in main.py)
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins for CORS
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
